{
  "name": "noveltrans",
  "version": "2.2.0",
  "description": "TypeScript-based project translator for long-form novel text.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minseung07/NovelTrans.git"
  },
  "bugs": {
    "url": "https://github.com/minseung07/NovelTrans/issues"
  },
  "homepage": "https://github.com/minseung07/NovelTrans#readme",
  "bin": {
    "noveltrans": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.json",
    "test": "node --test \"dist/**/*.test.js\"",
    "pretest": "npm run build:test",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "smoke": "npm run build && node dist/index.js self-test --workspace tmp/self-test"
  },
  "keywords": [
    "translation",
    "novel",
    "typescript",
    "cli"
  ],
  "author": "minseung07",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
